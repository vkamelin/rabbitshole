{% set cover = entry.coverImage is defined ? entry.cover.one() : null %}

<a href="{{ entry.url }}" class="card h-100 text-decoration-none text-reset">

    {# Обложка 2:3 #}
    <div class="card-img-top position-relative" style="padding-top: 150%; overflow: hidden;">

        {% if cover %}
            <img
                    src="{{ cover.url }}"
                    alt="{{ entry.title }}"
                    style="
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          object-fit: contain;
          background: #111;
        "
            >
        {% else %}
            <div class="d-flex align-items-center justify-content-center bg-secondary text-white"
                 style="position:absolute; inset:0;">
                Нет обложки
            </div>
        {% endif %}

    </div>

    {# Контент #}
    <div class="card-body">

        <div class="fw-bold mb-1">
            {{ entry.title }}
        </div>

        {% if entry.releaseDate %}
            <div class="text-muted small">
                {{ entry.releaseDate|date('Y') }}
            </div>
        {% endif %}

    </div>

</a>