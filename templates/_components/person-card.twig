{% set person = person ?? null %}

{% if person %}
    {% set imageAsset = null %}

    {% if person.photo is defined and person.photo %}
        {% set imageAsset = person.photo.one() %}
    {% elseif person.cover is defined and person.cover %}
        {% set imageAsset = person.cover.one() %}
    {% elseif person.image is defined and person.image %}
        {% set imageAsset = person.image.one() %}
    {% endif %}

    {% set personUrl = person.url ?? null %}

    <div class="col-6 col-md-3 col-xl-2">
        <div class="card h-100 overflow-hidden">
            {% if imageAsset %}
                <div class="ratio ratio-3x4 bg-dark">
                    {% if personUrl %}
                        <a href="{{ personUrl }}" class="d-block w-100 h-100 text-decoration-none">
                            <img
                                    src="{{ imageAsset.url }}"
                                    alt="{{ person.title }}"
                                    class="w-100 h-100 object-fit-cover"
                                    loading="lazy"
                            >
                        </a>
                    {% else %}
                        <img
                                src="{{ imageAsset.url }}"
                                alt="{{ person.title }}"
                                class="w-100 h-100 object-fit-cover"
                                loading="lazy"
                        >
                    {% endif %}
                </div>
            {% else %}
                <div class="ratio ratio-3x4 bg-secondary-lt d-flex align-items-center justify-content-center text-secondary">
                    {% if personUrl %}
                        <a href="{{ personUrl }}" class="d-flex align-items-center justify-content-center w-100 h-100 text-secondary text-decoration-none">
                            Нет фото
                        </a>
                    {% else %}
                        <span>Нет фото</span>
                    {% endif %}
                </div>
            {% endif %}

            <div class="card-body">
                {% if personUrl %}
                    <a href="{{ personUrl }}" class="text-body text-decoration-none fw-semibold small">
                        {{ person.title }}
                    </a>
                {% else %}
                    <div class="fw-semibold text-body">
                        {{ person.title }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endif %}