{% extends "_layouts/base" %}

{% set pageTitle = entry.title %}
{% set currentSection = 'series' %}

{# SEO #}
{% set cover = entry.seriesCover.one() %}

{# Title #}
{% set seoTitle = 'Hard Play смотрит ' ~ entry.title %}

{# Description #}
{% if entry.seoDescription %}
    {% set seoDescription = entry.seoDescription %}
{% elseif entry.description %}
    {% set seoDescription = entry.description|striptags|trim|replace({"\n": ' ', "\r": ' '})|slice(0, 160) %}
{% else %}
    {% set seoDescription = 'Запись стрима Hard Play: ' ~ entry.title ~ '.' %}
{% endif %}

{# OG Image #}
{% if cover %}
    {% set seoOgImage = cover.url %}
{% else %}
    {% set seoOgImage = '' %}
{% endif %}

{% block content %}
    {% set watchLinks = entry.watchLinks.all() %}
    {% set genres = entry.genres.all() %}
    {% set collections = entry.collections.all() %}

    <div class="row g-4">

        {# ===== ОБЛОЖКА ===== #}
        <div class="col-12 col-lg-4">
            <section class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0">
                    {% if cover %}
                        <div class="text-center bg-dark">
                            <img
                                    src="{{ cover.url }}"
                                    alt="Hard Play смотрит {{ entry.title }}"
                                    class="img-fluid w-100"
                                    style="aspect-ratio: 2 / 3; object-fit: contain;"
                                    loading="lazy"
                            >
                        </div>
                    {% else %}
                        <div
                                class="d-flex align-items-center justify-content-center bg-secondary-lt text-secondary"
                                style="width: 100%; aspect-ratio: 2 / 3;"
                        >
                            Нет обложки
                        </div>
                    {% endif %}
                </div>
            </section>
        </div>

        {# ===== ИНФОРМАЦИЯ ===== #}
        <div class="col-12 col-lg-8">
            <div class="card">
                <div class="card-body">

                    <div class="d-flex flex-column gap-4">

                        {# Заголовок + мета #}
                        <div>
                            <h1 class="mb-3">{{ entry.title }}</h1>
                        </div>


                        {# Описание #}
                        {% if entry.description %}
                            <div>
                                <h2 class="h3 mb-3">Описание</h2>

                                <div class="text-secondary">
                                    {{ entry.description }}
                                </div>
                            </div>
                        {% endif %}


                        {# Жанры #}
                        {% if genres %}
                            <div>
                                <h2 class="h3 mb-3">Жанры</h2>

                                <div class="d-flex flex-wrap gap-2">
                                    {% for genre in genres %}
                                        <span class="badge bg-green-lt">
                                            {{ genre.title }}
                                        </span>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}


                        {# Подборки #}
                        {% if collections %}
                            <div>
                                <h2 class="h3 mb-3">Подборки</h2>

                                <div class="d-flex flex-wrap gap-2">
                                    {% for collection in collections %}
                                        <span class="badge bg-orange-lt">
                                            {{ collection.title }}
                                        </span>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}


                        {# Ссылки #}
                        {% if watchLinks %}
                            <div class="d-flex flex-wrap gap-2 mt-auto">
                                <div class="btn-list">
                                {% for link in watchLinks %}
                                    {% if link.watchLink %}
                                        <a href="{{ link.watchLink }}" class="btn btn-orange" target="_blank" rel="noopener noreferrer">
                                            <i class="ti ti-player-play"></i>&nbsp;&nbsp;{{ link.title ?: 'Смотреть' }}
                                        </a>
                                    {% endif %}
                                {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                    </div>

                </div>
            </div>
        </div>

    </div>
{% endblock %}