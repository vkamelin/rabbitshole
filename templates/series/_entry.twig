{% extends "_layouts/base" %}

{% set pageTitle = entry.title %}

{% block content %}
    {% set cover = entry.cover.one() %}
    {% set watchLinks = entry.watchLinks.all() %}
    {% set genres = entry.genres.all() %}
    {% set collections = entry.collections.all() %}

    <div class="row g-4">

        {# ===== ОБЛОЖКА ===== #}
        <div class="col-12 col-lg-4">
            <div class="card">
                <div class="card-body">

                    {% if cover %}
                        <div class="text-center">
                            <img
                                    src="{{ cover.url }}"
                                    alt="{{ entry.title }}"
                                    class="img-fluid rounded"
                                    style="
                                    width: 100%;
                                    max-width: 420px;
                                    aspect-ratio: 2 / 3;
                                    object-fit: contain;
                                    background: #111;
                                "
                            >
                        </div>
                    {% else %}
                        <div
                                class="d-flex align-items-center justify-content-center rounded bg-secondary-lt text-secondary"
                                style="width: 100%; aspect-ratio: 2 / 3;"
                        >
                            Нет обложки
                        </div>
                    {% endif %}

                </div>
            </div>
        </div>


        {# ===== ИНФОРМАЦИЯ ===== #}
        <div class="col-12 col-lg-8">
            <div class="card">
                <div class="card-body">

                    <div class="d-flex flex-column gap-4">

                        {# Заголовок + мета #}
                        <div>
                            <h1 class="mb-3">{{ entry.title }}</h1>
                        </div>


                        {# Описание #}
                        {% if entry.description %}
                            <div>
                                <h2 class="h3 mb-3">Описание</h2>

                                <div class="text-secondary">
                                    {{ entry.description }}
                                </div>
                            </div>
                        {% endif %}


                        {# Жанры #}
                        {% if genres %}
                            <div>
                                <h2 class="h3 mb-3">Жанры</h2>

                                <div class="d-flex flex-wrap gap-2">
                                    {% for genre in genres %}
                                        <span class="badge bg-green-lt">
                                            {{ genre.title }}
                                        </span>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}


                        {# Подборки #}
                        {% if collections %}
                            <div>
                                <h2 class="h3 mb-3">Подборки</h2>

                                <div class="d-flex flex-wrap gap-2">
                                    {% for collection in collections %}
                                        <span class="badge bg-orange-lt">
                                            {{ collection.title }}
                                        </span>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}


                        {# Ссылки #}
                        {% if watchLinks %}
                            <div class="d-flex flex-wrap gap-2 mt-auto">
                                <div class="btn-list">
                                {% for link in watchLinks %}
                                    {% if link.watchLink %}
                                        <a href="{{ link.watchLink }}" class="btn btn-outline-indigo btn-sm" target="_blank" rel="noopener noreferrer">
                                            <i class="ti ti-player-play"></i>&nbsp;&nbsp;{{ link.label ?: 'Смотреть' }}
                                        </a>
                                    {% endif %}
                                {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                    </div>

                </div>
            </div>
        </div>

    </div>
{% endblock %}