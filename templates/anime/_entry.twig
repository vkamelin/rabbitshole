{% extends "_layouts/base" %}

{% set pageTitle = entry.title %}
{% set currentSection = 'anime' %}

{% set cover = entry.animeCover.one() %}
{% set seoTitle = 'Hard Play смотрит ' ~ entry.title %}

{% if entry.seoDescription %}
    {% set seoDescription = entry.seoDescription %}
{% elseif entry.description %}
    {% set seoDescription = entry.description|striptags|trim|replace({"\n": ' ', "\r": ' '})|slice(0, 160) %}
{% else %}
    {% set seoDescription = 'Запись стрима Hard Play: ' ~ entry.title ~ '.' %}
{% endif %}

{% if cover %}
    {% set seoOgImage = cover.url %}
{% else %}
    {% set seoOgImage = '' %}
{% endif %}

{% block styles %}
    <style>
        .watch-links {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
        }

        .watch-link {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            min-height: 2rem;
            padding: .35rem .65rem;
            border: 1px solid rgba(var(--tblr-orange-rgb), .45);
            border-radius: var(--tblr-border-radius);
            background: rgba(var(--tblr-orange-rgb), .08);
            color: var(--tblr-body-color);
            font-size: .875rem;
            font-weight: 600;
            text-decoration: none;
            max-width: 100%;
        }

        .watch-link__icon {
            color: var(--tblr-orange);
            flex: 0 0 auto;
        }

        .watch-link__text {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .watch-link:hover {
            border-color: rgba(var(--tblr-orange-rgb), .8);
            background: rgba(var(--tblr-orange-rgb), .16);
            color: var(--tblr-orange);
            text-decoration: none;
        }

        @media (max-width: 575.98px) {
            .watch-link {
                width: 100%;
            }

            .watch-link__text {
                white-space: normal;
            }
        }
    </style>
{% endblock %}

{% block content %}
    {% set watchLinks = entry.watchLinks is defined and entry.watchLinks ? entry.watchLinks.all() : [] %}
    {% set genres = entry.genres is defined and entry.genres ? entry.genres.all() : [] %}
    {% set collections = entry.collections is defined and entry.collections ? entry.collections.all() : [] %}
    {% set actors = entry.actors is defined and entry.actors ? entry.actors.all() : [] %}
    {% set directors = entry.directors is defined and entry.directors ? entry.directors.all() : [] %}
    {% set materialType = entry.type is defined and entry.type ? entry.type.name : (entry.section is defined and entry.section ? entry.section.name : 'Аниме') %}
    {% set validWatchLinks = [] %}
    {% for link in watchLinks %}
        {% if link.watchLink %}
            {% set validWatchLinks = validWatchLinks|merge([link]) %}
        {% endif %}
    {% endfor %}

    <div class="row g-4">
        <div class="col-12">
            <section class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-3 p-lg-4">
                    <div class="row g-4 align-items-start">
                        <div class="col-12 col-md-4 col-lg-3">
                            {% if cover %}
                                <div class="bg-dark rounded overflow-hidden">
                                    <img src="{{ cover.url }}" alt="{{ entry.title }}" class="img-fluid w-100" style="aspect-ratio: 2 / 3; object-fit: cover;" loading="lazy">
                                </div>
                            {% else %}
                                <div class="d-flex align-items-center justify-content-center bg-secondary-lt text-secondary rounded" style="aspect-ratio: 2 / 3;">
                                    Нет обложки
                                </div>
                            {% endif %}
                        </div>

                        <div class="col-12 col-md-8 col-lg-9 d-flex flex-column gap-3">
                            <div>
                                <h1 class="mb-2">{{ entry.title }}</h1>
                                <div class="d-flex flex-wrap gap-2">
                                    {% if materialType %}
                                        <span class="badge bg-azure-lt">{{ materialType }}</span>
                                    {% endif %}
                                    {% if entry.year is defined and entry.year %}
                                        <span class="badge bg-secondary-lt">{{ entry.year }}</span>
                                    {% endif %}
                                </div>
                            </div>

                            {% if genres %}
                                <div class="d-flex flex-wrap gap-2">
                                    {% for genre in genres %}
                                        <a href="{{ url('anime', { genre: genre.slug }) }}" class="badge bg-green-lt text-decoration-none">{{ genre.title }}</a>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            {% if collections %}
                                <div class="d-flex align-items-center flex-wrap gap-2">
                                    <span class="small text-secondary">Подборки:</span>
                                    {% for collection in collections %}
                                        <a href="{{ collection.url }}" class="badge bg-orange-lt text-decoration-none">{{ collection.title }}</a>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            {% if entry.description %}
                                <div class="text-secondary">{{ entry.description }}</div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </section>
        </div>

        {% if validWatchLinks|length %}
            <div class="col-12">
                <section class="card border-0 shadow-sm">
                    <div class="card-header">
                        <h2 class="card-title mb-0">Смотреть</h2>
                    </div>
                    <div class="card-body">
                        <div class="watch-links">
                            {% for link in validWatchLinks %}
                                <a href="{{ link.watchLink }}" class="watch-link" target="_blank" rel="noopener noreferrer" title="{{ link.title ?: 'Смотреть' }}">
                                    <span class="watch-link__icon"><i class="ti ti-player-play-filled"></i></span>
                                    <span class="watch-link__text">{{ link.title ?: 'Смотреть' }}</span>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </section>
            </div>
        {% endif %}

        {% if materialType or entry.year is defined and entry.year or genres or directors or collections %}
            <div class="col-12">
                <section class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h2 class="h3 mb-3">Информация</h2>
                        <div class="d-flex flex-column gap-3">
                            {% if materialType %}
                                <div>
                                    <div class="small text-secondary mb-1">Тип материала</div>
                                    <div class="fw-semibold">{{ materialType }}</div>
                                </div>
                            {% endif %}
                            {% if entry.year is defined and entry.year %}
                                <div>
                                    <div class="small text-secondary mb-1">Год</div>
                                    <div class="fw-semibold">{{ entry.year }}</div>
                                </div>
                            {% endif %}
                            {% if genres %}
                                <div>
                                    <div class="small text-secondary mb-1">Жанры</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        {% for genre in genres %}
                                            <a href="{{ url('anime', { genre: genre.slug }) }}" class="badge bg-green-lt text-decoration-none">{{ genre.title }}</a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                            {% if directors %}
                                <div>
                                    <div class="small text-secondary mb-1">{{ directors|length > 1 ? 'Режиссёры' : 'Режиссёр' }}</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        {% for director in directors %}
                                            <a href="{{ director.url }}" class="badge bg-indigo-lt text-decoration-none">{{ director.title }}</a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                            {% if collections %}
                                <div>
                                    <div class="small text-secondary mb-1">Подборки</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        {% for collection in collections %}
                                            <a href="{{ collection.url }}" class="badge bg-orange-lt text-decoration-none">{{ collection.title }}</a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </section>
            </div>
        {% endif %}

        {% if actors %}
            <div class="col-12">
                <h2 class="h3 mb-2">Актёры</h2>
                <div class="row g-2 g-md-3">
                    {% for actor in actors %}
                        {% set actorPhoto = actor.actorPhoto is defined and actor.actorPhoto ? actor.actorPhoto.one() : (actor.image is defined and actor.image ? actor.image.one() : null) %}
                        {% set nameParts = actor.title|trim|split(' ') %}
                        {% set initials = '' %}
                        {% for part in nameParts %}
                            {% if part and loop.index <= 2 %}
                                {% set initials = initials ~ part|first|upper %}
                            {% endif %}
                        {% endfor %}

                        <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                            <div class="card" style="min-height: 52px;">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-center gap-2">
                                        {% if actorPhoto %}
                                            <a href="{{ actor.url }}" class="text-decoration-none">
                                                <span class="avatar avatar-md rounded" style="background-image: url('{{ actorPhoto.url }}')"></span>
                                            </a>
                                        {% else %}
                                            <a href="{{ actor.url }}" class="text-decoration-none">
                                                <span class="avatar avatar-md bg-secondary-lt text-secondary fw-bold">{{ initials ?: 'A' }}</span>
                                            </a>
                                        {% endif %}
                                        <a href="{{ actor.url }}" class="text-body text-decoration-none fw-semibold" style="line-height: 1.2; word-break: break-word;">{{ actor.title }}</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
