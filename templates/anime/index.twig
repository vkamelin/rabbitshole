{% extends "_layouts/base" %}
{% set pageTitle = "Аниме" %}
{% set currentSection = 'anime' %}

{# SEO для страницы раздела #}
{% set sectionTitle = 'Аниме' %}
{% set sectionDescription = 'Каталог записей стримов Hard Play по разделу «Аниме».' %}
{% set sectionUrl = url('anime') %}

{# Проверка на фильтрацию #}
{% set request = craft.app.request %}
{% set hasFilters = request.getQueryParam('genre') or request.getQueryParam('collection') or request.getQueryParam('year') %}

{# Title #}
{% set seoTitle = sectionTitle ~ ' — стримы Hard Play' %}

{# Canonical #}
{% set seoCanonical = sectionUrl %}

{# Robots #}
{% if hasFilters %}
    {% set seoRobots = 'noindex,follow' %}
    {% set seoCanonical = sectionUrl %}
{% else %}
    {% set seoRobots = 'index,follow' %}
{% endif %}

{% set seo = {
    title: seoTitle,
    description: sectionDescription,
    canonical: seoCanonical,
    robots: seoRobots,
    ogType: 'website',
    ogTitle: seoTitle,
    ogDescription: sectionDescription,
    ogUrl: seoCanonical,
    ogImage: '',
    twitterTitle: seoTitle,
    twitterDescription: sectionDescription,
    twitterImage: ''
} %}

{% block content %}

    {% set entries = craft.entries()
        .section('anime')
        .orderBy('postDate DESC')
        .all()
    %}

    <div class="row">
        {% for entry in entries %}
            <div class="col-6 col-md-3 mb-3">
                {% include "_components/movie-card.twig" with { entry: entry } %}
            </div>
        {% endfor %}
    </div>

{% endblock %}