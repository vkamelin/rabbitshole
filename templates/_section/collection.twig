{% extends "_layouts/base" %}

{% set allowedSections = {
    movies: 'Кино',
    series: 'Сериалы',
    anime: 'Аниме',
    games: 'Игры',
    irl: 'IRL',
    reactions: 'Реакции'
} %}

{% set sectionTitle = allowedSections[sectionHandle] ?? null %}

{% if not sectionTitle %}
    {% exit 404 %}
{% endif %}

{% set collection = craft.categories()
    .group('collections')
    .slug(categorySlug)
    .one()
%}

{% if not collection %}
    {% exit 404 %}
{% endif %}

{% set pageTitle = 'Подборка: ' ~ collection.title %}

{# SEO для страницы категории подборки #}
{% if collection.seoDescription %}
    {% set seoDescription = collection.seoDescription %}
{% else %}
    {% set seoDescription = 'Подборка стримов Hard Play: ' ~ collection.title ~ '.' %}
{% endif %}

{% set seoTitle = collection.title ~ ' — подборка | rabbitshole.ru' %}

{% set seo = {
    title: seoTitle,
    description: seoDescription,
    canonical: collection.url,
    robots: 'index,follow',
    ogType: 'website',
    ogTitle: seoTitle,
    ogDescription: seoDescription,
    ogUrl: collection.url,
    ogImage: '',
    twitterTitle: seoTitle,
    twitterDescription: seoDescription,
    twitterImage: ''
} %}

{% block content %}

    {% set entries = craft.entries()
        .section(sectionHandle)
        .relatedTo(collection)
        .orderBy('postDate DESC')
        .all()
    %}

    <div class="d-flex flex-column gap-4">

        <div class="card">
            <div class="card-body">
                <div class="text-secondary mb-1">{{ sectionTitle }}</div>
                <h1 class="mb-0">Подборка: {{ collection.title }}</h1>
            </div>
        </div>

        {% if entries %}
            <div class="row">
                {% for entry in entries %}
                    <div class="col-6 col-md-3 mb-3">
                        {% include "_components/movie-card.twig" with { entry: entry } %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty">
                <div class="empty-header">0</div>
                <p class="empty-title">Ничего не найдено</p>
                <p class="empty-subtitle text-secondary">
                    В разделе «{{ sectionTitle }}» пока нет записей из подборки «{{ collection.title }}».
                </p>
            </div>
        {% endif %}

    </div>

{% endblock %}