{% extends "_layouts/base" %}

{% set pageTitle = category.title %}
{% set currentSection = 'actors' %}

{% block title %}{{ pageTitle }} — {{ siteName ?? 'Кроличья нора' }}{% endblock %}

{% block content %}
    {% set cover = category.actorPhoto.one() ?? null %}
    {% set relatedEntries = craft.entries()
        .section(['movies', 'series'])
        .relatedTo(category)
        .orderBy('postDate desc')
        .limit(24)
        .all()
    %}

    <div class="mb-3">
        <a href="{{ url('actors') }}" class="btn btn-sm">
            ← Все актеры
        </a>
    </div>

    <div class="row g-4 align-items-start">
        <div class="col-12 col-lg-4">
            <section class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0">
                    {% if cover %}
                        <div class="text-center bg-dark">
                            <img
                                    src="{{ cover.url }}"
                                    alt="{{ category.title }}"
                                    class="img-fluid w-100"
                                    style="aspect-ratio: 2 / 3; object-fit: cover;"
                                    loading="lazy"
                            >
                        </div>
                    {% else %}
                        <div
                                class="d-flex align-items-center justify-content-center bg-secondary-lt text-secondary"
                                style="width: 100%; aspect-ratio: 2 / 3;"
                        >
                            Нет фото
                        </div>
                    {% endif %}
                </div>
            </section>
        </div>

        <div class="col-12 col-lg-8">
            <section class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 p-lg-5">
                    <div class="d-flex flex-column gap-4 h-100">
                        <div>
                            <h1 class="display-5 fw-bold mb-3">{{ category.title }}</h1>

                            {% if category.description %}
                                <div class="text-secondary">
                                    {{ category.description }}
                                </div>
                            {% else %}
                                <p class="text-secondary mb-0">
                                    Описание скоро появится.
                                </p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>

    {% if relatedEntries %}
        <section class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-transparent border-0 pb-0">
                <h2 class="card-title mb-0">Фильмы и сериалы</h2>
            </div>

            <div class="card-body">
                <div class="row row-cards">
                    {% for entryItem in relatedEntries %}
                        <div class="col-6 col-md-3 col-xl-2">
                            {% include "_components/content-card" with {
                                entry: entryItem
                            } only %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}
{% endblock %}