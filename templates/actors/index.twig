{% extends "_layouts/base" %}

{% set pageTitle = 'Актеры' %}
{% set currentSection = 'actors' %}

{% block title %}{{ pageTitle }} — {{ siteName ?? 'Кроличья нора' }}{% endblock %}

{% block content %}
    {% set categories = craft.categories()
        .group('actors')
        .orderBy('title asc')
        .all()
    %}

    {% set femaleActors = categories|filter(c => c.female == true) %}
    {% set maleActors = categories|filter(c => c.female != true) %}

    <div class="mb-4">
        <h1 class="display-5 fw-bold mb-3">{{ pageTitle }}</h1>
        <p class="text-secondary">
            Все актеры, которые появлялись в стримах Hard Play. Используйте фильтры для поиска по полу.
        </p>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0">
                    <h2 class="card-title mb-0">Фильтры</h2>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a href="#all" class="list-group-item list-group-item-action active" data-filter="all">
                            Все актеры
                            <span class="badge bg-primary rounded-pill float-end">{{ categories|length }}</span>
                        </a>
                        <a href="#male" class="list-group-item list-group-item-action" data-filter="male">
                            Мужчины
                            <span class="badge bg-secondary rounded-pill float-end">{{ maleActors|length }}</span>
                        </a>
                        <a href="#female" class="list-group-item list-group-item-action" data-filter="female">
                            Женщины
                            <span class="badge bg-secondary rounded-pill float-end">{{ femaleActors|length }}</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-9">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                    <h2 class="card-title mb-0">Список актеров</h2>
                    <div class="d-flex gap-2">
                        <div class="input-group input-group-sm" style="max-width: 300px;">
                            <span class="input-group-text">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                                </svg>
                            </span>
                            <input type="text" class="form-control" placeholder="Поиск актера..." id="actorSearch">
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    {% if categories %}
                        <div class="row row-cards" id="actorsContainer">
                            {% for actor in categories %}
                                {% include "_components/person-card" with {
                                    person: actor
                                } only %}
                            {% endfor %}
                        </div>

                        {% if categories|length == 0 %}
                            <div class="text-center py-5">
                                <div class="text-secondary mb-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-person-x" viewBox="0 0 16 16">
                                        <path d="M11 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0M8 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m.256 7a4.5 4.5 0 0 1-.229-1.004H3c.001-.246.154-.986.832-1.664C4.484 10.68 5.711 10 8 10c.26 0 .507.009.74.025.226-.341.496-.65.804-.918C9.077 9.038 8.564 9 8 9c-5 0-6 3-6 4s1 1 1 1z"/>
                                        <path d="M12.5 16a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7m-.646-4.854.646.647.646-.647a.5.5 0 0 1 .708.708l-.647.646.647.646a.5.5 0 0 1-.708.708l-.646-.647-.646.647a.5.5 0 0 1-.708-.708l.647-.646-.647-.646a.5.5 0 0 1 .708-.708"/>
                                    </svg>
                                </div>
                                <h3 class="h4">Актеры не найдены</h3>
                                <p class="text-secondary">Попробуйте изменить параметры фильтрации</p>
                            </div>
                        {% endif %}
                    {% else %}
                        <div class="text-center py-5">
                            <div class="text-secondary mb-3">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-people" viewBox="0 0 16 16">
                                    <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002a.274.274 0 0 1-.014.002H7.022ZM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.493 5.493 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4"/>
                                </svg>
                            </div>
                            <h3 class="h4">Актеры еще не добавлены</h3>
                            <p class="text-secondary">В каталоге пока нет актеров. Они появятся позже.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block js %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const filterLinks = document.querySelectorAll('[data-filter]');
            const searchInput = document.getElementById('actorSearch');
            const actorItems = document.querySelectorAll('.actor-item');
            
            function filterActors() {
                const activeFilter = document.querySelector('[data-filter].active')?.dataset.filter || 'all';
                const searchTerm = searchInput.value.toLowerCase().trim();
                
                actorItems.forEach(item => {
                    const gender = item.dataset.gender;
                    const name = item.dataset.name;
                    const matchesFilter = activeFilter === 'all' || gender === activeFilter;
                    const matchesSearch = searchTerm === '' || name.includes(searchTerm);
                    
                    if (matchesFilter && matchesSearch) {
                        item.style.display = 'block';
                    } else {
                        item.style.display = 'none';
                    }
                });
            }
            
            filterLinks.forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    filterLinks.forEach(l => l.classList.remove('active'));
                    this.classList.add('active');
                    
                    filterActors();
                });
            });
            
            searchInput.addEventListener('input', filterActors);
            
            // Инициализация фильтрации
            filterActors();
        });
    </script>
{% endblock %}