{% extends "_layouts/base" %}

{% set pageTitle = 'Актеры' %}
{% set currentSection = 'actors' %}

{% block title %}{{ pageTitle }} — {{ siteName ?? 'Кроличья нора' }}{% endblock %}

{% block content %}
    {% set request = craft.app.request %}
    {% set genderFilter = request.getQueryParam('gender') %}
    {% set searchQuery = request.getQueryParam('search') ?? '' %}
    {% set sortBy = request.getQueryParam('sortBy') ?? 'title' %}

    {# Базовый запрос для получения всех актеров с фото #}
    {% set baseQuery = craft.categories()
        .group('actors')
    %}

    {% if genderFilter == 'female' %}
        {% set baseQuery = baseQuery.female(true) %}
    {% elseif genderFilter == 'male' %}
        {% set baseQuery = baseQuery.female(false) %}
    {% endif %}

    {# Получаем всех актеров для последующей фильтрации и подсчета #}
    {% set allActors = baseQuery.status(null).all() %}

    {# Фильтрация по поиску #}
    {% if searchQuery %}
        {% set filteredActors = [] %}
        {% for actor in allActors %}
            {% if searchQuery|lower in actor.title|lower %}
                {% set filteredActors = filteredActors|merge([actor]) %}
            {% endif %}
        {% endfor %}
        {% set allActors = filteredActors %}
    {% endif %}

    {# Подсчет фильмов для каждого актера (используем кэширование) #}
    {% set movieCounts = {} %}
    {% if sortBy == 'movieCount' and allActors|length > 0 %}
        {% for actor in allActors %}
            {% set cacheKey = 'actor_movie_count_' ~ actor.id ~ '_' ~ craft.app.request.siteId %}
            {% set movieCount = craft.app.cache.getOrSet(cacheKey, 86400, function() {
                return craft.entries()
                    .section(['movies', 'series'])
                    .relatedTo(actor)
                    .status(null)
                    .count()
            }) %}
            {% set movieCounts = movieCounts|merge({(actor.id): movieCount}) %}
        {% endfor %}

        {# Сортировка по количеству фильмов (убывание), затем по имени (возрастание) #}
        {% set allActors = allActors|sort((a, b) => 
            movieCounts[b.id]|default(0) <=> movieCounts[a.id]|default(0) 
            ?: a.title <=> b.title
        ) %}
    {% else %}
        {# Сортировка по имени (А-Я) #}
        {% set allActors = allActors|sort((a, b) => a.title <=> b.title) %}
    {% endif %}

    {# Пагинация #}
    {% set itemsPerPage = 48 %}
    {% set totalActors = allActors|length %}
    {% set totalPages = (totalActors / itemsPerPage)|ceil %}
    {% set currentPage = (request.getQueryParam('p') | default(1)) | max(1) %}
    {% set currentPage = currentPage > totalPages ? totalPages : currentPage %}
    {% set offset = (currentPage - 1) * itemsPerPage %}
    {% set actors = allActors|slice(offset, itemsPerPage) %}

    {% set femaleActorsCount = allActors|filter(a => a.female == true)|length %}
    {% set maleActorsCount = allActors|filter(a => a.female != true)|length %}

    {% set hasFilters = genderFilter or searchQuery or sortBy %}

    {# URL для пагинации с сохранением параметров #}
    {% set baseUrl = 'actors' %}
    {% set currentParams = {} %}
    {% if genderFilter %}{% set currentParams = currentParams|merge({gender: genderFilter}) %}{% endif %}
    {% if searchQuery %}{% set currentParams = currentParams|merge({search: searchQuery}) %}{% endif %}
    {% if sortBy != 'title' %}{% set currentParams = currentParams|merge({sortBy: sortBy}) %}{% endif %}

    {# Title с пагинацией #}
    {% if currentPage > 1 %}
        {% set seoTitle = pageTitle ~ ' — страница ' ~ currentPage %}
    {% else %}
        {% set seoTitle = pageTitle %}
    {% endif %}

    <section class="mb-4">
        <div class="card border-0 bg-dark text-white overflow-hidden">
            <div class="card-body p-4 p-lg-5">
                <div class="row g-4 align-items-center">
                    <div class="col-12 col-xl-7">
                        <div class="text-uppercase text-secondary fw-semibold small mb-2">Каталог rabbitshole.ru</div>
                        <h1 class="display-4 fw-bold mb-3">Актеры</h1>
                        <p class="lead text-secondary mb-0">
                            Все актеры, которые появлялись в стримах Hard Play. Всего: {{ totalActors }}
                        </p>
                    </div>
                    <div class="col-12 col-xl-5">
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="card bg-white-lt border-0 h-100">
                                    <div class="card-body text-center py-3">
                                        <div class="h1 mb-1">{{ femaleActorsCount }}</div>
                                        <div class="text-secondary small">Женщин</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card bg-white-lt border-0 h-100">
                                    <div class="card-body text-center py-3">
                                        <div class="h1 mb-1">{{ maleActorsCount }}</div>
                                        <div class="text-secondary small">Мужчин</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <form method="get" class="row g-3 align-items-end">
                        <div class="col-12 col-md-4">
                            <label for="genderFilter" class="form-label">Пол</label>
                            <select id="genderFilter" name="gender" class="form-select">
                                <option value="">Все актеры</option>
                                <option value="female" {{ genderFilter == 'female' ? 'selected' }}>Женщины</option>
                                <option value="male" {{ genderFilter == 'male' ? 'selected' }}>Мужчины</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-4">
                            <label for="searchQuery" class="form-label">Поиск по имени</label>
                            <input
                                type="text"
                                id="searchQuery"
                                name="search"
                                class="form-control"
                                value="{{ searchQuery }}"
                                placeholder="Введите имя актера"
                            >
                        </div>

                        <div class="col-12 col-md-4">
                            <label for="sortBy" class="form-label">Сортировка</label>
                            <select id="sortBy" name="sortBy" class="form-select">
                                <option value="title" {{ sortBy == 'title' ? 'selected' }}>По имени (А-Я)</option>
                                <option value="movieCount" {{ sortBy == 'movieCount' ? 'selected' }}>По количеству фильмов</option>
                            </select>
                        </div>

                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Применить</button>
                            <a href="{{ url('actors') }}" class="btn btn-outline-secondary">Сбросить</a>
                        </div>
                    </form>

                    {% if hasFilters %}
                        <div class="mt-4 pt-3 border-top">
                            <span class="text-secondary small">Активные фильтры:</span>
                            <div class="d-flex flex-wrap gap-2 mt-2">
                                {% if genderFilter %}
                                    <span class="badge bg-primary-lt">
                                        {{ genderFilter == 'female' ? 'Женщины' : 'Мужчины' }}
                                        <a href="{{ url('actors', { search: searchQuery }) }}" class="text-white ms-1" title="Убрать фильтр">×</a>
                                    </span>
                                {% endif %}
                                {% if searchQuery %}
                                    <span class="badge bg-blue-lt">
                                        Поиск: "{{ searchQuery }}"
                                        <a href="{{ url('actors', { gender: genderFilter }) }}" class="text-white ms-1" title="Убрать фильтр">×</a>
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {% if actors and actors|length > 0 %}
        <div class="row row-cards" id="actorsContainer">
            {% for actor in actors %}
                {% set actorMovieCount = movieCounts[actor.id]|default(0) %}
                {% include "_components/person-card" with {
                    person: actor,
                    movieCount: actorMovieCount
                } only %}
            {% endfor %}
        </div>

        {% if totalPages > 1 %}
            <nav class="mt-4 d-flex justify-content-center">
                <ul class="pagination">
                    {% if currentPage > 1 %}
                        {% set prevParams = currentParams|merge({p: currentPage - 1}) %}
                        <li class="page-item">
                            <a class="page-link" href="{{ url(baseUrl, prevParams) }}">←</a>
                        </li>
                    {% endif %}

                    {% set startPage = max(1, currentPage - 2) %}
                    {% set endPage = min(totalPages, currentPage + 2) %}

                    {% for page in startPage..endPage %}
                        {% if page == currentPage %}
                            <li class="page-item active">
                                <span class="page-link">{{ page }}</span>
                            </li>
                        {% else %}
                            {% set pageParams = currentParams|merge({p: page}) %}
                            <li class="page-item">
                                <a class="page-link" href="{{ url(baseUrl, pageParams) }}">{{ page }}</a>
                            </li>
                        {% endif %}
                    {% endfor %}

                    {% if currentPage < totalPages %}
                        {% set nextParams = currentParams|merge({p: currentPage + 1}) %}
                        <li class="page-item">
                            <a class="page-link" href="{{ url(baseUrl, nextParams) }}">→</a>
                        </li>
                    {% endif %}
                </ul>
            </nav>
        {% endif %}
    {% else %}
        <div class="text-center py-5">
            <div class="text-secondary mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-people" viewBox="0 0 16 16">
                    <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002a.274.274 0 0 1-.014.002H7.022ZM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.493 5.493 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4"/>
                </svg>
            </div>
            <h3 class="h4">Актеры не найдены</h3>
            <p class="text-secondary">Попробуйте изменить параметры фильтрации или вернуться ко всему каталогу.</p>
            <a href="{{ url('actors') }}" class="btn btn-primary">Сбросить фильтры</a>
        </div>
    {% endif %}
{% endblock %}
