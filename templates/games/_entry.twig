{% extends "_layouts/base" %}

{% set pageTitle = entry.title %}
{% set currentSection = 'games' %}

{# SEO #}
{% set cover = entry.cover.one() %}

{# Title #}
{% set seoTitle = 'Hard Play играет в ' ~ entry.title %}

{# Description #}
{% if entry.seoDescription %}
    {% set seoDescription = entry.seoDescription %}
{% elseif entry.description %}
    {% set seoDescription = entry.description|striptags|trim|replace({"\n": ' ', "\r": ' '})|slice(0, 160) %}
{% else %}
    {% set seoDescription = 'Запись стрима Hard Play: ' ~ entry.title ~ '.' %}
{% endif %}

{# OG Image #}
{% if cover %}
    {% set seoOgImage = cover.url %}
{% else %}
    {% set seoOgImage = '' %}
{% endif %}

{% set seo = {
    title: seoTitle,
    description: seoDescription,
    canonical: entry.url,
    robots: 'index,follow',
    ogType: 'article',
    ogTitle: seoTitle,
    ogDescription: seoDescription,
    ogUrl: entry.url,
    ogImage: seoOgImage,
    twitterTitle: seoTitle,
    twitterDescription: seoDescription,
    twitterImage: seoOgImage
} %}

{% block content %}
    {% set watchLinks = entry.watchLinks.all() %}
    {% set genres = entry.genres.all() %}
    {% set collections = entry.collections.all() %}

    <div class="row g-4">

        {# Обложка #}
        <div class="col-12 col-lg-4">
            <div class="card">
                <div class="card-body">

                    {% if cover %}
                        <div class="text-center">
                            <img
                                    src="{{ cover.url }}"
                                    alt="{{ entry.title }}"
                                    class="img-fluid rounded"
                                    style="
                                    width: 100%;
                                    max-width: 420px;
                                    aspect-ratio: 2 / 3;
                                    object-fit: contain;
                                    background: #111;
                                "
                            >
                        </div>
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-secondary-lt text-secondary rounded"
                             style="aspect-ratio: 2 / 3;">
                            Нет обложки
                        </div>
                    {% endif %}

                </div>
            </div>
        </div>

        {# Информация #}
        <div class="col-12 col-lg-8">
            <div class="card">
                <div class="card-body">

                    <h1 class="mb-3">{{ entry.title }}</h1>

                    {% if entry.description %}
                        <div class="mb-4">
                            <h2 class="h4">Описание</h2>
                            <div class="text-secondary">
                                {{ entry.description }}
                            </div>
                        </div>
                    {% endif %}

                    {% if genres %}
                        <div class="mb-4">
                            <h2 class="h4">Жанры</h2>
                            <div class="d-flex flex-wrap gap-2">
                                {% for genre in genres %}
                                    <span class="badge bg-green-lt">{{ genre.title }}</span>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    {% if collections %}
                        <div class="mb-4">
                            <h2 class="h4">Подборки</h2>
                            <div class="d-flex flex-wrap gap-2">
                                {% for collection in collections %}
                                    <span class="badge bg-orange-lt">{{ collection.title }}</span>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    {% if watchLinks %}
                        <div class="mt-auto mb-4">
                            <h2 class="h3 mb-3">Ссылки на просмотр</h2>

                            <div class="d-flex flex-wrap gap-2">
                                {% for link in watchLinks %}
                                    {% if link.watchLink %}
                                        <a
                                                href="{{ link.watchLink }}"
                                                class="btn btn-orange"
                                                target="_blank"
                                                rel="noopener noreferrer"
                                        >
                                            <i class="ti ti-player-play"></i>&nbsp;&nbsp;{{ link.label ?: 'Смотреть' }}
                                        </a>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                </div>
            </div>
        </div>

    </div>
{% endblock %}