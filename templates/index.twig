{% extends "_layouts/base" %}
{% set pageTitle = "Главная" %}

{# SEO для главной страницы #}
{% set seoTitle = 'Кроличья нора — каталог записей стримов Hard Play' %}
{% set seoDescription = 'Каталог записей стримов Hard Play: кино, сериалы, аниме, игры, IRL и реакции.' %}

{% set seo = {
    title: seoTitle,
    description: seoDescription,
    canonical: siteUrl,
    robots: 'index,follow',
    ogType: 'website',
    ogTitle: seoTitle,
    ogDescription: seoDescription,
    ogUrl: siteUrl,
    ogImage: '',
    twitterTitle: seoTitle,
    twitterDescription: seoDescription,
    twitterImage: ''
} %}

{% block content %}

    {# ================= HERO (цитата) ================= #}
    {% set quote = craft.entries.section('quotes').orderBy('RAND()').one() %}

    {% if quote %}
        <div class="row mb-4">
            <div class="col-12">
                <div class="card card-lg">
                    <div class="card-body text-center">
                        <blockquote class="blockquote mb-0">
                            <p>“{{ quote.text }}”</p>
                            {% if quote.source %}
                                <footer class="blockquote-footer mt-2">
                                    {{ quote.source }}
                                </footer>
                            {% endif %}
                        </blockquote>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}


    {# ================= ПОСЛЕДНИЕ ЗАПИСИ ================= #}
    {% set latestEntries = craft.entries()
        .section(['movies', 'series', 'anime', 'games', 'irl', 'reactions'])
        .orderBy('postDate DESC')
        .limit(12)
        .all()
    %}

    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-3">Последние записи</h2>
        </div>

        {% for entry in latestEntries %}
            <div class="col-6 col-md-3 mb-3">
                {% include "_components/movie-card.twig" with { entry: entry } %}
            </div>
        {% endfor %}
    </div>


    {# ================= РАЗДЕЛЫ ================= #}

    {% set sections = [
        { handle: 'movies', title: 'Кино' },
        { handle: 'series', title: 'Сериалы' },
        { handle: 'anime', title: 'Аниме' },
        { handle: 'games', title: 'Игры' },
        { handle: 'irl', title: 'IRL' },
        { handle: 'reactions', title: 'Реакции' }
    ] %}

    {% for section in sections %}

        {% set entries = craft.entries()
            .section(section.handle)
            .orderBy('postDate DESC')
            .limit(6)
            .all()
        %}

        {% if entries %}
            <div class="row mb-5">

                <div class="col-12 d-flex justify-content-between align-items-center mb-3">
                    <h2 class="mb-0">{{ section.title }}</h2>

                    <a href="/{{ section.handle }}" class="btn btn-sm btn-primary">
                        Смотреть все
                    </a>
                </div>

                {% for entry in entries %}
                    <div class="col-6 col-md-2 mb-3">
                        {% include "_components/movie-card.twig" with { entry: entry } %}
                    </div>
                {% endfor %}

            </div>
        {% endif %}

    {% endfor %}

{% endblock %}