{# templates/_layouts/base.twig #}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#0f172a">

    {# SEO Meta Tags #}
    {% if seo is defined %}
        <title>{{ seo.title }}</title>
        <meta name="description" content="{{ seo.description }}">
        <link rel="canonical" href="{{ seo.canonical }}">
        <meta name="robots" content="{{ seo.robots }}">

        <meta property="og:type" content="{{ seo.ogType }}">
        <meta property="og:site_name" content="rabbitshole.ru">
        <meta property="og:title" content="{{ seo.ogTitle }}">
        <meta property="og:description" content="{{ seo.ogDescription }}">
        <meta property="og:url" content="{{ seo.ogUrl }}">

        {% if seo.ogImage %}
            <meta property="og:image" content="{{ seo.ogImage }}">
        {% endif %}

        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{{ seo.twitterTitle }}">
        <meta name="twitter:description" content="{{ seo.twitterDescription }}">

        {% if seo.twitterImage %}
            <meta name="twitter:image" content="{{ seo.twitterImage }}">
        {% endif %}
    {% else %}
        <title>{% block title %}{{ siteName ?? 'Кроличья нора' }}{% endblock %}</title>
        <meta name="description" content="{% block metaDescription %}Каталог записей стримов Hard Play{% endblock %}">
        <meta name="robots" content="{% block robots %}index,follow{% endblock %}">
    {% endif %}

    {% block meta %}{% endblock %}

    <link rel="icon" href="/favicon.png" sizes="any">

    {# Tabler CSS #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
    <link rel="stylesheet" href="/assets/css/app.css">

    {% block head %}{% endblock %}

    <meta name="yandex-verification" content="8f17e9ee31e67560" />

    <!-- Yandex.Metrika counter -->
    <script type="text/javascript">     (function(m,e,t,r,i,k,a){         m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};         m[i].l=1*new Date();         for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}         k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)     })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=108290995', 'ym');      ym(108290995, 'init', {ssr:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true}); </script> <noscript><div><img src="https://mc.yandex.ru/watch/108290995" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Yandex.Metrika counter -->
</head>
<body class="
    layout-fluid
    {% block bodyClass %}{{ bodyClass ?? '' }}{% endblock %}
">
<div class="page">
    {# Header #}
    <header class="navbar navbar-expand-md navbar-light d-print-none border-bottom bg-white">
        <div class="container-xl">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#site-navbar" aria-controls="site-navbar" aria-expanded="false" aria-label="Переключить навигацию">
                <span class="navbar-toggler-icon"></span>
            </button>

            <h1 class="navbar-brand navbar-brand-autodark pe-0 pe-md-3 m-0">
                <a href="{{ siteUrl }}">
                    <span class="fw-bold text-body">🐰 Кроличья нора</span>
                </a>
            </h1>

            <div class="collapse navbar-collapse" id="site-navbar">
                <ul class="navbar-nav ms-auto">
                    {% set navItems = [
                        { key: 'movies', label: 'Кино', url: '/movies' },
                        { key: 'series', label: 'Сериалы', url: '/series' },
                        { key: 'anime', label: 'Аниме', url: '/anime' },
                        { key: 'games', label: 'Игры', url: '/games' },
                        { key: 'irl', label: 'IRL', url: '/irl' },
                        { key: 'reactions', label: 'Реакции', url: '/reactions' }
                    ] %}

                    {% for item in navItems %}
                        <li class="nav-item">
                            <a
                                    href="{{ item.url }}"
                                    class="nav-link {% if currentSection is defined and currentSection == item.key %}active{% endif %}"
                            >
                                <span class="nav-link-title">{{ item.label }}</span>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </header>

    {# Page wrapper #}
    <div class="page-wrapper">
        {# Flash / alerts #}
        {% block alerts %}
            {% if craft.app.session.hasFlash('success') %}
                <div class="container-xl mt-3">
                    <div class="alert alert-success" role="alert">
                        {{ craft.app.session.getFlash('success') }}
                    </div>
                </div>
            {% endif %}

            {% if craft.app.session.hasFlash('error') %}
                <div class="container-xl mt-3">
                    <div class="alert alert-danger" role="alert">
                        {{ craft.app.session.getFlash('error') }}
                    </div>
                </div>
            {% endif %}

            {% if craft.app.session.hasFlash('warning') %}
                <div class="container-xl mt-3">
                    <div class="alert alert-warning" role="alert">
                        {{ craft.app.session.getFlash('warning') }}
                    </div>
                </div>
            {% endif %}

            {% if craft.app.session.hasFlash('info') %}
                <div class="container-xl mt-3">
                    <div class="alert alert-info" role="alert">
                        {{ craft.app.session.getFlash('info') }}
                    </div>
                </div>
            {% endif %}
        {% endblock %}

        {# Main content #}
        <main class="page-body">
            <div class="container-xl">
                {% block content %}{% endblock %}
            </div>
        </main>

        {# Footer #}
        <footer class="footer footer-transparent d-print-none border-top mt-auto">
            <div class="container-xl">
                <div class="row text-center align-items-center flex-row-reverse">
                    <div class="col-lg-auto ms-lg-auto">
                        <ul class="list-inline list-inline-dots mb-0">
                            <li class="list-inline-item">
                                <a href="/movies" class="link-secondary">Кино</a>
                            </li>
                            <li class="list-inline-item">
                                <a href="/series" class="link-secondary">Сериалы</a>
                            </li>
                            <li class="list-inline-item">
                                <a href="/anime" class="link-secondary">Аниме</a>
                            </li>
                            <li class="list-inline-item">
                                <a href="/games" class="link-secondary">Игры</a>
                            </li>
                            <li class="list-inline-item">
                                <a href="/irl" class="link-secondary">IRL</a>
                            </li>
                            <li class="list-inline-item">
                                <a href="/reactions" class="link-secondary">Реакции</a>
                            </li>
                        </ul>
                    </div>
                    <div class="col-12 col-lg-auto mt-3 mt-lg-0">
                        <p class="mb-0 text-secondary">
                            © {{ now|date('Y') }} {{ siteName ?? 'rabbitshole.ru' }} — каталог записей стримов Hard Play
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </div>
</div>

{# JS #}
<script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/js/tabler.min.js"></script>
<script src="/assets/js/app.js"></script>

{% block footerScripts %}{% endblock %}
</body>
</html>