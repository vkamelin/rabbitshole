{# templates/_layouts/base.twig #}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8">
    <title>{% block title %}{{ siteName ?? 'Кроличья нора' }}{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{% block metaDescription %}Каталог записей стримов Hard Play{% endblock %}">
    <meta name="robots" content="{% block robots %}index,follow{% endblock %}">
    <meta name="theme-color" content="#0f172a">

    {% block meta %}{% endblock %}

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    {# Tabler CSS #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
    <link rel="stylesheet" href="/assets/css/app.css">

    {% block head %}{% endblock %}
</head>
<body class="
    layout-fluid
    {% block bodyClass %}{{ bodyClass ?? '' }}{% endblock %}
">
<div class="page">
    {# Header #}
    <header class="navbar navbar-expand-md navbar-light d-print-none border-bottom bg-white">
        <div class="container-xl">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#site-navbar" aria-controls="site-navbar" aria-expanded="false" aria-label="Переключить навигацию">
                <span class="navbar-toggler-icon"></span>
            </button>

            <h1 class="navbar-brand navbar-brand-autodark pe-0 pe-md-3 m-0">
                <a href="{{ siteUrl }}">
                    <span class="fw-bold text-body">🐰 Кроличья нора</span>
                </a>
            </h1>

            <div class="collapse navbar-collapse" id="site-navbar">
                <ul class="navbar-nav ms-auto">
                    {% set navItems = [
                        { key: 'movies', label: 'Кино', url: '/movies' },
                        { key: 'series', label: 'Сериалы', url: '/series' },
                        { key: 'anime', label: 'Аниме', url: '/anime' },
                        { key: 'games', label: 'Игры', url: '/games' },
                        { key: 'irl', label: 'IRL', url: '/irl' },
                        { key: 'reactions', label: 'Реакции', url: '/reactions' }
                    ] %}

                    {% for item in navItems %}
                        <li class="nav-item">
                            <a
                                    href="{{ item.url }}"
                                    class="nav-link {% if currentSection is defined and currentSection == item.key %}active{% endif %}"
                            >
                                <span class="nav-link-title">{{ item.label }}</span>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </header>

    {# Page wrapper #}
    <div class="page-wrapper">
        {# Flash / alerts #}
        {% block alerts %}
            {% if craft.app.session.hasFlash('success') %}
                <div class="container-xl mt-3">
                    <div class="alert alert-success" role="alert">
                        {{ craft.app.session.getFlash('success') }}
                    </div>
                </div>
            {% endif %}

            {% if craft.app.session.hasFlash('error') %}
                <div class="container-xl mt-3">
                    <div class="alert alert-danger" role="alert">
                        {{ craft.app.session.getFlash('error') }}
                    </div>
                </div>
            {% endif %}

            {% if craft.app.session.hasFlash('warning') %}
                <div class="container-xl mt-3">
                    <div class="alert alert-warning" role="alert">
                        {{ craft.app.session.getFlash('warning') }}
                    </div>
                </div>
            {% endif %}

            {% if craft.app.session.hasFlash('info') %}
                <div class="container-xl mt-3">
                    <div class="alert alert-info" role="alert">
                        {{ craft.app.session.getFlash('info') }}
                    </div>
                </div>
            {% endif %}
        {% endblock %}

        {# Main content #}
        <main class="page-body">
            <div class="container-xl">
                {% block content %}{% endblock %}
            </div>
        </main>

        {# Footer #}
        <footer class="footer footer-transparent d-print-none border-top mt-auto">
            <div class="container-xl">
                <div class="row text-center align-items-center flex-row-reverse">
                    <div class="col-lg-auto ms-lg-auto">
                        <ul class="list-inline list-inline-dots mb-0">
                            <li class="list-inline-item">
                                <a href="/movies" class="link-secondary">Кино</a>
                            </li>
                            <li class="list-inline-item">
                                <a href="/series" class="link-secondary">Сериалы</a>
                            </li>
                            <li class="list-inline-item">
                                <a href="/anime" class="link-secondary">Аниме</a>
                            </li>
                            <li class="list-inline-item">
                                <a href="/games" class="link-secondary">Игры</a>
                            </li>
                            <li class="list-inline-item">
                                <a href="/irl" class="link-secondary">IRL</a>
                            </li>
                            <li class="list-inline-item">
                                <a href="/reactions" class="link-secondary">Реакции</a>
                            </li>
                        </ul>
                    </div>
                    <div class="col-12 col-lg-auto mt-3 mt-lg-0">
                        <p class="mb-0 text-secondary">
                            © {{ now|date('Y') }} {{ siteName ?? 'rabbitshole.ru' }} — каталог записей стримов Hard Play
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </div>
</div>

{# JS #}
<script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/js/tabler.min.js"></script>
<script src="/assets/js/app.js"></script>

{% block footerScripts %}{% endblock %}
</body>
</html>