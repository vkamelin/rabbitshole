{% extends "_layouts/base" %}

{% set pageTitle = 'Фильмы' %}
{% set currentSection = 'movies' %}

{% block title %}{{ pageTitle }} — {{ siteName ?? 'Кроличья нора' }}{% endblock %}

{% block content %}
    {% set request = craft.app.request %}
    {% set selectedGenre = request.getQueryParam('genre') %}
    {% set selectedCollection = request.getQueryParam('collection') %}

    {% set allGenres = craft.categories().group('genres').orderBy('title asc').all() %}
    {% set allCollections = craft.categories().group('collections').orderBy('title asc').all() %}

    {% set activeGenre = selectedGenre ? craft.categories().group('genres').slug(selectedGenre).one() : null %}
    {% set activeCollection = selectedCollection ? craft.categories().group('collections').slug(selectedCollection).one() : null %}

    {% set query = craft.entries().section('movies').orderBy('postDate desc') %}

    {% set relatedFilters = [] %}
    {% if activeGenre %}
        {% set relatedFilters = relatedFilters|merge([{ targetElement: activeGenre }]) %}
    {% endif %}
    {% if activeCollection %}
        {% set relatedFilters = relatedFilters|merge([{ targetElement: activeCollection }]) %}
    {% endif %}

    {% if relatedFilters|length == 1 %}
        {% set query = query.relatedTo(relatedFilters|first) %}
    {% elseif relatedFilters|length > 1 %}
        {% set query = query.relatedTo(['and']|merge(relatedFilters)) %}
    {% endif %}

    {% paginate query.limit(12) as pageInfo, entries %}

    {% set totalMovies = craft.entries().section('movies').count() %}
    {% set totalGenres = allGenres|length %}
    {% set totalCollections = allCollections|length %}

    {% set resetUrl = url('movies') %}

    <section class="mb-4">
        <div class="card border-0 bg-dark text-white overflow-hidden">
            <div class="card-body p-4 p-lg-5">
                <div class="row g-4 align-items-center">
                    <div class="col-12 col-xl-7">
                        <div class="text-uppercase text-secondary fw-semibold small mb-2">Каталог rabbitshole.ru</div>
                        <h1 class="display-4 fw-bold mb-3">Фильмы</h1>
                        <p class="lead text-secondary mb-0">
                            Коллекция фильмов с атмосферой стримов Hard Play: выбирайте по жанрам и подборкам, открывайте карточку и переходите к просмотру.
                        </p>
                    </div>
                    <div class="col-12 col-xl-5">
                        <div class="row g-3">
                            <div class="col-4">
                                <div class="card bg-white-lt border-0 h-100">
                                    <div class="card-body text-center py-3">
                                        <div class="h1 mb-1">{{ totalMovies }}</div>
                                        <div class="text-secondary small">Фильмов</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="card bg-white-lt border-0 h-100">
                                    <div class="card-body text-center py-3">
                                        <div class="h1 mb-1">{{ totalGenres }}</div>
                                        <div class="text-secondary small">Жанров</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="card bg-white-lt border-0 h-100">
                                    <div class="card-body text-center py-3">
                                        <div class="h1 mb-1">{{ totalCollections }}</div>
                                        <div class="text-secondary small">Подборок</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="mb-4">
                    <h3 class="h4 mb-3">Жанры</h3>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ url('movies', activeCollection ? { collection: activeCollection.slug } : {}) }}"
                           class="btn btn-sm {{ not activeGenre ? 'btn-primary' : 'btn-outline-primary' }}">
                            Все жанры
                        </a>
                        {% for genre in allGenres %}
                            {% set genreUrlParams = { genre: genre.slug } %}
                            {% if activeCollection %}
                                {% set genreUrlParams = genreUrlParams|merge({ collection: activeCollection.slug }) %}
                            {% endif %}
                            <a href="{{ url('movies', genreUrlParams) }}"
                               class="btn btn-sm {{ activeGenre and activeGenre.id == genre.id ? 'btn-primary' : 'btn-outline-primary' }}">
                                {{ genre.title }}
                            </a>
                        {% else %}
                            <span class="text-secondary">Жанры пока не добавлены.</span>
                        {% endfor %}
                    </div>
                </div>

                {% if activeGenre or activeCollection %}
                    <div class="mt-4 pt-3 border-top d-flex flex-wrap align-items-center gap-2">
                        <span class="text-secondary">Активные фильтры:</span>
                        {% if activeGenre %}
                            <span class="badge bg-primary-lt">Жанр: {{ activeGenre.title }}</span>
                        {% endif %}
                        {% if activeCollection %}
                            <span class="badge bg-orange-lt">Подборка: {{ activeCollection.title }}</span>
                        {% endif %}
                        <a href="{{ resetUrl }}" class="btn btn-sm btn-outline-secondary ms-md-auto">Сбросить фильтры</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    {% if entries %}
        <section>
            <div class="row row-cards">
                {% for movie in entries %}
                    {% set movieCover = movie.cover.one() %}
                    {% set movieGenres = movie.genres.all() %}
                    {% set movieCollections = movie.collections.all() %}
                    {% set movieWatchLinks = movie.watchLinks.all() %}

                    <div class="col-12 col-md-6 col-xl-4">
                        <article class="card card-link h-100 shadow-sm">
                            <a href="{{ movie.url }}" class="text-decoration-none text-reset">
                                {% if movieCover %}
                                    <img src="{{ movieCover.url }}" alt="{{ movie.title }}" class="card-img-top" loading="lazy">
                                {% else %}
                                    <div class="card-img-top ratio ratio-4x3 bg-secondary-lt d-flex align-items-center justify-content-center text-secondary">
                                        Нет обложки
                                    </div>
                                {% endif %}
                            </a>

                            <div class="card-body d-flex flex-column gap-3">
                                <div>
                                    <h3 class="h2 mb-2">
                                        <a href="{{ movie.url }}" class="text-decoration-none text-body">{{ movie.title }}</a>
                                    </h3>
                                    <div class="d-flex flex-wrap gap-2 text-secondary">
                                        {% if movie.year %}
                                            <span class="badge bg-blue-lt">{{ movie.year }}</span>
                                        {% endif %}
                                        {% if movie.duration %}
                                            <span class="badge bg-azure-lt">{{ movie.duration|date('H:i') }}</span>
                                        {% endif %}
                                        {% if movieWatchLinks|length > 1 %}
                                            <span class="badge bg-green-lt">{{ movieWatchLinks|length }} ссылок</span>
                                        {% elseif movieWatchLinks|length == 1 %}
                                            <span class="badge bg-green-lt">1 ссылка</span>
                                        {% endif %}
                                    </div>
                                </div>

                                {% if movie.description %}
                                    <p class="text-secondary mb-0">{{ movie.description|striptags|truncate(140) }}</p>
                                {% else %}
                                    <p class="text-secondary mb-0">Описание пока не добавлено.</p>
                                {% endif %}

                                {% if movieGenres %}
                                    <div class="d-flex flex-wrap gap-2">
                                        {% for genre in movieGenres|slice(0, 3) %}
                                            <a href="{{ url('movies', { genre: genre.slug }) }}" class="badge bg-primary-lt text-decoration-none">{{ genre.title }}</a>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                {% if movieCollections %}
                                    <div class="d-flex flex-wrap gap-2">
                                        {% for collection in movieCollections|slice(0, 2) %}
                                            <a href="{{ url('movies', { collection: collection.slug }) }}" class="badge bg-orange-lt text-decoration-none">{{ collection.title }}</a>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                <div class="mt-auto">
                                    <a href="{{ movie.url }}" class="btn w-100">Открыть</a>
                                </div>
                            </div>
                        </article>
                    </div>
                {% endfor %}
            </div>

            {% if pageInfo.totalPages > 1 %}
                <nav class="mt-4 d-flex justify-content-center">
                    <ul class="pagination">

                        {% if pageInfo.prevUrl %}
                            <li class="page-item">
                                <a class="page-link" href="{{ pageInfo.prevUrl }}">←</a>
                            </li>
                        {% endif %}

                        {% for page, url in pageInfo.getPrevUrls(2) %}
                            <li class="page-item">
                                <a class="page-link" href="{{ url }}">{{ page }}</a>
                            </li>
                        {% endfor %}

                        <li class="page-item active">
                            <span class="page-link">{{ pageInfo.currentPage }}</span>
                        </li>

                        {% for page, url in pageInfo.getNextUrls(2) %}
                            <li class="page-item">
                                <a class="page-link" href="{{ url }}">{{ page }}</a>
                            </li>
                        {% endfor %}

                        {% if pageInfo.nextUrl %}
                            <li class="page-item">
                                <a class="page-link" href="{{ pageInfo.nextUrl }}">→</a>
                            </li>
                        {% endif %}

                    </ul>
                </nav>
            {% endif %}
        </section>
    {% else %}
        <section>
            <div class="card border-0 shadow-sm">
                <div class="card-body py-5 text-center">
                    <div class="avatar avatar-xl bg-secondary-lt mx-auto mb-3">🎥</div>
                    <h2 class="h1 mb-2">Фильмы не найдены</h2>
                    <p class="text-secondary mb-4">Попробуйте изменить параметры фильтрации или вернуться ко всему каталогу.</p>
                    <a href="{{ resetUrl }}" class="btn btn-primary">Сбросить фильтры</a>
                </div>
            </div>
        </section>
    {% endif %}
{% endblock %}
