{% extends "_layouts/base" %}

{% set pageTitle = 'Фильмы' %}
{% set currentSection = 'movies' %}

{% block content %}
    {% set request = craft.app.request %}
    {% set selectedGenre = request.getQueryParam('genre') %}
    {% set selectedYear = request.getQueryParam('year') %}
    {% set selectedRatingMin = request.getQueryParam('ratingMin') %}
    {% set selectedRatingMax = request.getQueryParam('ratingMax') %}

    {% set allGenres = craft.categories()
        .group('genres')
        .relatedTo({
            sourceElement: craft.entries().section('movies')
        })
        .orderBy('title asc')
        .all()
    %}

    {% set activeGenre = selectedGenre ? craft.categories().group('genres').slug(selectedGenre).one() : null %}

    {% set query = craft.entries()
        .section('movies')
        .orderBy('postDate desc')
    %}

    {% if activeGenre %}
        {% set query = query.relatedTo({ targetElement: activeGenre }) %}
    {% endif %}

    {% if selectedYear %}
        {% set query = query.year(selectedYear) %}
    {% endif %}

    {% if selectedRatingMin %}
        {% set query = query.rating('>= ' ~ selectedRatingMin) %}
    {% endif %}

    {% if selectedRatingMax %}
        {% set query = query.rating('<= ' ~ selectedRatingMax) %}
    {% endif %}

    {% paginate query.limit(12) as pageInfo, entries %}

    {# SEO для страницы раздела #}
    {% set sectionTitle = 'Кино' %}
    {% set sectionDescription = 'Каталог записей стримов Hard Play по разделу «Кино».' %}
    {% set sectionUrl = url('movies') %}

    {% set hasFilters = selectedGenre or selectedYear or selectedRatingMin or selectedRatingMax %}

    {# Title с пагинацией #}
    {% if pageInfo.currentPage > 1 %}
        {% set seoTitle = sectionTitle ~ ' — стримы Hard Play — страница ' ~ pageInfo.currentPage %}
    {% else %}
        {% set seoTitle = sectionTitle ~ ' — стримы Hard Play' %}
    {% endif %}

    {# Canonical #}
    {% if pageInfo.currentPage > 1 %}
        {% set seoCanonical = pageInfo.currentUrl %}
    {% else %}
        {% set seoCanonical = sectionUrl %}
    {% endif %}

    {# Robots #}
    {% if hasFilters %}
        {% set seoRobots = 'noindex,follow' %}
        {% set seoCanonical = sectionUrl %}
    {% else %}
        {% set seoRobots = 'index,follow' %}
    {% endif %}

    {% set seo = {
        title: seoTitle,
        description: sectionDescription,
        canonical: seoCanonical,
        robots: seoRobots,
        ogType: 'website',
        ogTitle: seoTitle,
        ogDescription: sectionDescription,
        ogUrl: seoCanonical,
        ogImage: '',
        twitterTitle: seoTitle,
        twitterDescription: sectionDescription,
        twitterImage: ''
    } %}

    {% set totalMovies = craft.entries().section('movies').count() %}
    {% set totalGenres = allGenres|length %}
    {% set resetUrl = url('movies') %}

    <section class="mb-4">
        <div class="card border-0 bg-dark text-white overflow-hidden">
            <div class="card-body p-4 p-lg-5">
                <div class="row g-4 align-items-center">
                    <div class="col-12 col-xl-7">
                        <div class="text-uppercase text-secondary fw-semibold small mb-2">Каталог rabbitshole.ru</div>
                        <h1 class="display-4 fw-bold mb-3">Фильмы</h1>
                        <p class="lead text-secondary mb-0">
                            Коллекция фильмов с атмосферой стримов Hard Play: выбирайте по жанрам, году и рейтингу, открывайте карточку и переходите к просмотру.
                        </p>
                    </div>
                    <div class="col-12 col-xl-5">
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="card bg-white-lt border-0 h-100">
                                    <div class="card-body text-center py-3">
                                        <div class="h1 mb-1">{{ totalMovies }}</div>
                                        <div class="text-secondary small">Фильмов</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card bg-white-lt border-0 h-100">
                                    <div class="card-body text-center py-3">
                                        <div class="h1 mb-1">{{ totalGenres }}</div>
                                        <div class="text-secondary small">Жанров</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="mb-4">
                    <h3 class="h4 mb-3">Жанры</h3>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ url('movies', {
                            year: selectedYear,
                            ratingMin: selectedRatingMin,
                            ratingMax: selectedRatingMax
                        }) }}"
                           class="btn btn-sm {{ not activeGenre ? 'btn-primary' : 'btn-outline-primary' }}">
                            Все жанры
                        </a>

                        {% for genre in allGenres %}
                            <a href="{{ url('movies', {
                                genre: genre.slug,
                                year: selectedYear,
                                ratingMin: selectedRatingMin,
                                ratingMax: selectedRatingMax
                            }) }}"
                               class="btn btn-sm {{ activeGenre and activeGenre.id == genre.id ? 'btn-primary' : 'btn-outline-primary' }}">
                                {{ genre.title }}
                            </a>
                        {% else %}
                            <span class="text-secondary">Жанры пока не добавлены.</span>
                        {% endfor %}
                    </div>
                </div>

                <form method="get" class="row g-3">
                    {% if activeGenre %}
                        <input type="hidden" name="genre" value="{{ activeGenre.slug }}">
                    {% endif %}

                    <div class="col-12 col-md-4">
                        <label for="year" class="form-label">Год</label>
                        <input
                                type="number"
                                id="year"
                                name="year"
                                min="1900"
                                max="2100"
                                step="1"
                                class="form-control"
                                value="{{ selectedYear }}"
                                placeholder="Например, 2024"
                        >
                    </div>

                    <div class="col-12 col-md-4">
                        <label for="ratingMin" class="form-label">Рейтинг от</label>
                        <input
                                type="number"
                                id="ratingMin"
                                name="ratingMin"
                                min="0"
                                max="10"
                                step="0.1"
                                class="form-control"
                                value="{{ selectedRatingMin }}"
                                placeholder="Например, 7.0"
                        >
                    </div>

                    <div class="col-12 col-md-4">
                        <label for="ratingMax" class="form-label">Рейтинг до</label>
                        <input
                                type="number"
                                id="ratingMax"
                                name="ratingMax"
                                min="0"
                                max="10"
                                step="0.1"
                                class="form-control"
                                value="{{ selectedRatingMax }}"
                                placeholder="Например, 8.5"
                        >
                    </div>

                    <div class="col-12 d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary">Применить фильтры</button>
                        <a href="{{ resetUrl }}" class="btn btn-outline-secondary">Сбросить</a>
                    </div>
                </form>

                {% if activeGenre or selectedYear or selectedRatingMin or selectedRatingMax %}
                    <div class="mt-4 pt-3 border-top d-flex flex-wrap align-items-center gap-2">
                        <span class="text-secondary">Активные фильтры:</span>

                        {% if activeGenre %}
                            <span class="badge bg-primary-lt">Жанр: {{ activeGenre.title }}</span>
                        {% endif %}

                        {% if selectedYear %}
                            <span class="badge bg-blue-lt">Год: {{ selectedYear }}</span>
                        {% endif %}

                        {% if selectedRatingMin %}
                            <span class="badge bg-indigo-lt">Рейтинг от: {{ selectedRatingMin }}</span>
                        {% endif %}

                        {% if selectedRatingMax %}
                            <span class="badge bg-indigo-lt">Рейтинг до: {{ selectedRatingMax }}</span>
                        {% endif %}

                        <a href="{{ resetUrl }}" class="btn btn-sm btn-outline-secondary ms-md-auto">Сбросить фильтры</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    {% if entries %}
        <section>
            <div class="row row-cards">
                {% for movie in entries %}
                    <div class="col-6 col-md-3 col-xl-2">
                        {% include "_components/content-card" with {
                            entry: movie
                        } only %}
                    </div>
                {% endfor %}
            </div>

            {% if pageInfo.totalPages > 1 %}
                <nav class="mt-4 d-flex justify-content-center">
                    <ul class="pagination">
                        {% if pageInfo.prevUrl %}
                            <li class="page-item">
                                <a class="page-link" href="{{ pageInfo.prevUrl }}">←</a>
                            </li>
                        {% endif %}

                        {% for page, url in pageInfo.getPrevUrls(2) %}
                            <li class="page-item">
                                <a class="page-link" href="{{ url }}">{{ page }}</a>
                            </li>
                        {% endfor %}

                        <li class="page-item active">
                            <span class="page-link">{{ pageInfo.currentPage }}</span>
                        </li>

                        {% for page, url in pageInfo.getNextUrls(2) %}
                            <li class="page-item">
                                <a class="page-link" href="{{ url }}">{{ page }}</a>
                            </li>
                        {% endfor %}

                        {% if pageInfo.nextUrl %}
                            <li class="page-item">
                                <a class="page-link" href="{{ pageInfo.nextUrl }}">→</a>
                            </li>
                        {% endif %}
                    </ul>
                </nav>
            {% endif %}
        </section>
    {% else %}
        <section>
            <div class="card border-0 shadow-sm">
                <div class="card-body py-5 text-center">
                    <div class="avatar avatar-xl bg-secondary-lt mx-auto mb-3">🎥</div>
                    <h2 class="h1 mb-2">Фильмы не найдены</h2>
                    <p class="text-secondary mb-4">Попробуйте изменить параметры фильтрации или вернуться ко всему каталогу.</p>
                    <a href="{{ resetUrl }}" class="btn btn-primary">Сбросить фильтры</a>
                </div>
            </div>
        </section>
    {% endif %}
{% endblock %}