{% extends "_layouts/base" %}

{% set pageTitle = entry.title %}
{% set currentSection = 'movies' %}

{# SEO #}
{% set cover = entry.movieCover.one() %}
{% set bigCover = entry.bigCover.one() %}

{# Title #}
{% set seoTitle = 'Hard Play смотрит ' ~ entry.title %}

{# Description #}
{% if entry.seoDescription %}
	{% set seoDescription = entry.seoDescription %}
{% elseif entry.description %}
	{% set seoDescription = entry.description|striptags|trim|replace({"\n": ' ', "\r": ' '})|slice(0, 160) %}
{% else %}
	{% set seoDescription = 'Запись стрима Hard Play: ' ~ entry.title ~ '.' %}
{% endif %}

{# OG Image #}
{% if cover %}
	{% set seoOgImage = cover.url %}
{% else %}
	{% set seoOgImage = '' %}
{% endif %}

{% set rating = entry.rating is defined ? entry.rating : null %}

{% set ratingBadgeClass = 'bg-secondary text-white' %}
{% if rating is not null %}
	{% if rating >= 8.5 %}
		{% set ratingBadgeClass = 'bg-green text-green-fg' %}
	{% elseif rating >= 7.0 %}
		{% set ratingBadgeClass = 'bg-lime text-lime-fg' %}
	{% elseif rating >= 5.5 %}
		{% set ratingBadgeClass = 'bg-yellow text-yellow-fg' %}
	{% elseif rating >= 4.0 %}
		{% set ratingBadgeClass = 'bg-orange text-orange-fg' %}
	{% else %}
		{% set ratingBadgeClass = 'bg-red text-red-fg' %}
	{% endif %}
{% endif %}

{% block styles %}
	{% if bigCover %}
		<style>
			.movie-hero-bg {
				background-image: url("{{ bigCover.url }}");
			}

			.movie-hero-bg {
				position: relative;
				width: 100vw;
				margin-left: calc(-50vw + 50%);
				aspect-ratio: 16 / 9;
				background-size: cover;
				background-position: center center;
				background-repeat: no-repeat;
			}

			.movie-hero-bg::after {
				content: "";
				position: absolute;
				bottom: 0;
				left: 0;
				width: 100%;
				height: 30%;
				background: linear-gradient(to bottom, rgba(17, 24, 39, 0) 0%, rgba(17, 24, 39, 1) 100%);
			}

			@media(max-width: 768px) {
				.movie-hero-bg {
					background-position: center top;
				}
			}

			@media (min-width: 768px) {
				.movie-content-wrapper {
					position: relative;
					z-index: 1;
					margin-top: -20%;
				}

				.page-body {
					margin-top: 0 !important;
				}
			}

			@media (min-width: 1650px) {
				.movie-content-wrapper {
					margin-top: -30%;
				}
			}

			.movie-content-wrapper .card-body {
				border-radius: 0.5rem;
			}

			.person-list-item {
				min-height: 52px;
			}

			.person-list-name {
				line-height: 1.2;
				word-break: break-word;
			}
		</style>
	{% else %}
		<style>
			.person-list-item {
				min-height: 52px;
			}

			.person-list-name {
				line-height: 1.2;
				word-break: break-word;
			}
		</style>
	{% endif %}
{% endblock %}

{% block content %}
	{% set genres = entry.genres.all() %}
	{% set collections = entry.collections.all() %}
	{% set watchLinks = entry.watchLinks.all() %}
	{% set actors = entry.actors is defined ? entry.actors.all() : [] %}
	{% set directors = entry.directors is defined ? entry.directors.all() : [] %}
	{% set materialType = entry.type is defined and entry.type ? entry.type.name : (entry.section is defined and entry.section ? entry.section.name : 'Кино') %}
	{% set visibleActors = actors|slice(0, 16) %}
	{% set hiddenActors = actors|slice(16) %}

	{% if bigCover %}
		<div class="movie-hero-bg d-none d-sm-block"></div>
		<div class="movie-hero-gradientd-none d-sm-block"></div>
	{% endif %}

	<div class="movie-content-wrapper">

		<div class="row g-4 align-items-start">
			{# ===== ОБЛОЖКА ===== #}
			<div class="col-12 col-lg-4 col-md-3 d-flex flex-column d-sm-none d-md-flex">
				<section class="card border-0 shadow overflow-hidden">
					<div class="card-body p-0">
						{% if cover %}
							<div class="text-center bg-dark">
								<a href="{{ cover.url }}" data-lightbox="gallery" title="{{ entry.title }}">
									<img src="{{ cover.getUrl('thumb') }}" alt="{{ entry.title }}" class="w-100 h-100 object-fit-cover" loading="lazy">

									<div class="position-absolute h2 top-0 start-0 w-100 p-2 d-flex justify-content-end align-items-start gap-2">
										{% if rating is not null %}
											<span class="badge {{ ratingBadgeClass }}" title="Рейтинг Кинопоиска">
												★ {{ rating }}
											</span>
										{% endif %}

										{% if entry.duration %}
											<span class="badge bg-purple text-purple-fg" title="Продолжительность">{{ entry.duration|date('H:i') }}</span>
										{% endif %}
									</div>
								</a>
							</div>
						{% else %}
							<div class="d-flex align-items-center justify-content-center bg-secondary-lt text-secondary" style="width: 100%; aspect-ratio: 2 / 3;">
								Нет обложки
							</div>
						{% endif %}
					</div>
				</section>
			</div>

			{# ===== ИНФОРМАЦИЯ ===== #}
			<div class="col-12 col-lg-8 col-md-9">
				<section class="card border-0 shadow-sm h-100">
					<div class="card-body p-4 p-lg-5">
						<div class="d-flex flex-column gap-2 h-100">

							<div class="mb-3">
								<a href="{{ url('movies') }}" class="btn btn-sm btn-outline-light">
									← Назад к фильмам
								</a>

								{% if currentUser and currentUser.can('editEntries') %}
									<a href="/admin/content/entries/movies/{{ entry.id }}-{{ entry.slug }}" class="btn btn-primary btn-sm">
										<i class="ti ti-edit"></i>
										Редактировать
									</a>
								{% endif %}
							</div>

							<h1 class="display-6 fw-bold mb-3 d-flex justify-content-start align-items-center">
								{{ entry.title }}{% if entry.year %} ({{ entry.year }}){% endif %}
							</h1>

							<div class="d-flex flex-wrap gap-2 mb-2">
								{% if materialType %}
									<span class="badge bg-azure-lt">{{ materialType }}</span>
								{% endif %}

								{% if entry.year %}
									<span class="badge bg-secondary-lt">{{ entry.year }}</span>
								{% endif %}
							</div>

							<div class="d-flex flex-wrap gap-2 mb-3">
								{% if genres %}
									<div>
										{% for genre in genres %}
											<a href="{{ url('movies', { genre: genre.slug }) }}" class="badge bg-blue text-blue-fg text-decoration-none" title="Жанр: {{ genre.title }}">
												{{ genre.title }}
											</a>
										{% endfor %}
									</div>
								{% endif %}

								{% if collections %}
									<div class="w-100 d-flex align-items-center gap-2 flex-wrap">
										<span class="small text-secondary">Подборки:</span>
										{% for collection in collections %}
											<a href="{{ collection.url }}" class="badge bg-orange-lt text-decoration-none" title="Подборка: {{ collection.title }}">
												{{ collection.title }}
											</a>
										{% endfor %}
									</div>
								{% endif %}
							</div>

							{% if watchLinks %}
								<div class="mt-auto mb-4">
									<h2 class="h3 mb-3">Ссылки на просмотр</h2>

									<div class="d-flex flex-wrap gap-2">
										{% for link in watchLinks %}
											{% if link.watchLink %}
												<a href="{{ link.watchLink }}" class="btn btn-orange btn-lg" target="_blank" rel="noopener noreferrer">
													<i class="ti ti-player-play"></i>&nbsp;&nbsp;{{ link.title ?: 'Смотреть' }}
												</a>
											{% endif %}
										{% endfor %}
									</div>
								</div>
							{% endif %}

							{% if entry.description %}
								<div class="text-secondary">
									{{ entry.description }}
								</div>
							{% else %}
								<p class="lead text-secondary mb-0">Описание фильма скоро появится.</p>
							{% endif %}
						</div>
					</div>
				</section>
			</div>

			{% if directors %}
				<div class="col-12">
					<section class="card border-0 shadow-sm">
						<div class="card-body">
							<h2 class="h3 mb-3">Информация</h2>

							<div class="d-flex flex-column gap-3">
								<div>
									<div class="small text-secondary mb-1">Год</div>
									<div class="fw-semibold">{{ entry.year ?: '—' }}</div>
								</div>

								<div>
									<div class="small text-secondary mb-1">Тип материала</div>
									<div class="fw-semibold">{{ materialType ?: '—' }}</div>
								</div>

								{% if genres %}
									<div>
										<div class="small text-secondary mb-1">Жанры</div>
										<div class="d-flex flex-wrap gap-2">
											{% for genre in genres %}
												<a href="{{ url('movies', { genre: genre.slug }) }}" class="badge bg-blue text-blue-fg text-decoration-none">{{ genre.title }}</a>
											{% endfor %}
										</div>
									</div>
								{% endif %}

								<div>
									<div class="small text-secondary mb-1">{{ directors|length > 1 ? 'Режиссёры' : 'Режиссёр' }}</div>
									<div class="d-flex flex-wrap gap-2">
										{% for director in directors %}
											<a href="{{ director.url }}" class="badge bg-indigo-lt text-decoration-none">{{ director.title }}</a>
										{% endfor %}
									</div>
								</div>

								{% if collections %}
									<div>
										<div class="small text-secondary mb-1">Подборки</div>
										<div class="d-flex flex-wrap gap-2">
											{% for collection in collections %}
												<a href="{{ collection.url }}" class="badge bg-orange-lt text-decoration-none">{{ collection.title }}</a>
											{% endfor %}
										</div>
									</div>
								{% endif %}
							</div>
						</div>
					</section>
				</div>
			{% endif %}

			{% if not directors and (entry.year or materialType or genres or collections) %}
				<div class="col-12">
					<section class="card border-0 shadow-sm">
						<div class="card-body">
							<h2 class="h3 mb-3">Информация</h2>

							<div class="d-flex flex-column gap-3">
								<div>
									<div class="small text-secondary mb-1">Год</div>
									<div class="fw-semibold">{{ entry.year ?: '—' }}</div>
								</div>

								<div>
									<div class="small text-secondary mb-1">Тип материала</div>
									<div class="fw-semibold">{{ materialType ?: '—' }}</div>
								</div>

								{% if genres %}
									<div>
										<div class="small text-secondary mb-1">Жанры</div>
										<div class="d-flex flex-wrap gap-2">
											{% for genre in genres %}
												<a href="{{ url('movies', { genre: genre.slug }) }}" class="badge bg-blue text-blue-fg text-decoration-none">{{ genre.title }}</a>
											{% endfor %}
										</div>
									</div>
								{% endif %}

								{% if collections %}
									<div>
										<div class="small text-secondary mb-1">Подборки</div>
										<div class="d-flex flex-wrap gap-2">
											{% for collection in collections %}
												<a href="{{ collection.url }}" class="badge bg-orange-lt text-decoration-none">{{ collection.title }}</a>
											{% endfor %}
										</div>
									</div>
								{% endif %}
							</div>
						</div>
					</section>
				</div>
			{% endif %}


			{% if actors %}
				<div class="col-12">
					<h2 class="h3 mb-2">Актёры</h2>

					<div class="row g-2 g-md-3">
						{% for actor in visibleActors %}
							{% set actorPhoto = actor.actorPhoto is defined and actor.actorPhoto ? actor.actorPhoto.one() : (actor.image is defined and actor.image ? actor.image.one() : null) %}
							{% set nameParts = actor.title|trim|split(' ') %}
							{% set initials = '' %}
							{% for part in nameParts %}
								{% if part and loop.index <= 2 %}
									{% set initials = initials ~ part|first|upper %}
								{% endif %}
							{% endfor %}

							<div class="col-12 col-sm-6 col-lg-4 col-xl-3">
								<div class="card person-list-item">
									<div class="card-body py-2 px-3">
										<div class="d-flex align-items-center gap-2">
											{% if actorPhoto %}
												<a href="{{ actor.url }}" class="text-decoration-none">
													<span class="avatar avatar-md rounded" style="background-image: url('{{ actorPhoto.url }}')"></span>
												</a>
											{% else %}
												<a href="{{ actor.url }}" class="text-decoration-none">
													<span class="avatar avatar-md bg-secondary-lt text-secondary fw-bold">{{ initials ?: 'A' }}</span>
												</a>
											{% endif %}

											<a href="{{ actor.url }}" class="text-body text-decoration-none fw-semibold person-list-name">
												{{ actor.title }}
											</a>
										</div>
									</div>
								</div>
							</div>
						{% endfor %}
					</div>

					{% if hiddenActors %}
						<details class="mt-3">
							<summary class="btn btn-outline-secondary btn-sm">Показать всех актёров (ещё {{ hiddenActors|length }})</summary>

							<div class="row g-2 g-md-3 mt-2">
								{% for actor in hiddenActors %}
									{% set actorPhoto = actor.actorPhoto is defined and actor.actorPhoto ? actor.actorPhoto.one() : (actor.image is defined and actor.image ? actor.image.one() : null) %}
									{% set nameParts = actor.title|trim|split(' ') %}
									{% set initials = '' %}
									{% for part in nameParts %}
										{% if part and loop.index <= 2 %}
											{% set initials = initials ~ part|first|upper %}
										{% endif %}
									{% endfor %}

									<div class="col-12 col-sm-6 col-lg-4 col-xl-3">
										<div class="card person-list-item">
											<div class="card-body py-2 px-3">
												<div class="d-flex align-items-center gap-2">
													{% if actorPhoto %}
														<a href="{{ actor.url }}" class="text-decoration-none">
															<span class="avatar avatar-md rounded" style="background-image: url('{{ actorPhoto.url }}')"></span>
														</a>
													{% else %}
														<a href="{{ actor.url }}" class="text-decoration-none">
															<span class="avatar avatar-md bg-secondary-lt text-secondary fw-bold">{{ initials ?: 'A' }}</span>
														</a>
													{% endif %}

													<a href="{{ actor.url }}" class="text-body text-decoration-none fw-semibold person-list-name">
														{{ actor.title }}
													</a>
												</div>
											</div>
										</div>
									</div>
								{% endfor %}
							</div>
						</details>
					{% endif %}
				</div>
			{% endif %}

		</div>
	</div>
{% endblock %}
