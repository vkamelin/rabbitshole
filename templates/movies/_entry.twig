{% extends "_layouts/base" %}

{% set pageTitle = entry.title %}
{% set currentSection = 'movies' %}

{% block title %}{{ pageTitle }} — {{ siteName ?? 'Кроличья нора' }}{% endblock %}

{% block content %}
    {% set cover = entry.cover.one() %}
    {% set genres = entry.genres.all() %}
    {% set collections = entry.collections.all() %}
    {% set watchLinks = entry.watchLinks.all() %}

    {% set primaryWatchLink = watchLinks|first %}

    <div class="mb-3">
        <a href="{{ url('movies') }}" class="btn btn-sm">
            ← Назад к фильмам
        </a>
    </div>

    <div class="row g-4 align-items-start">
        <div class="col-12">
            <section class="card border-0 shadow-sm overflow-hidden mb-4">
                <div class="row g-0">
                    <div class="col-12 col-md-5 col-lg-4">
                        {% if cover %}
                            <img src="{{ cover.url }}" alt="{{ entry.title }}" class="w-100 h-100 object-fit-cover" loading="lazy">
                        {% else %}
                            <div class="h-100 d-flex align-items-center justify-content-center bg-secondary-lt text-secondary p-5">
                                Нет обложки
                            </div>
                        {% endif %}
                    </div>

                    <div class="col-12 col-md-7 col-lg-8">
                        <div class="card-body p-4 p-lg-5 d-flex flex-column gap-4 h-100">
                            <div>
                                <h1 class="display-5 fw-bold mb-3">{{ entry.title }}</h1>
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    {% if entry.year %}
                                        <span class="badge bg-blue-lt">Год: {{ entry.year }}</span>
                                    {% endif %}
                                    {% if entry.duration %}
                                        <span class="badge bg-azure-lt">Длительность: {{ entry.duration|date('H:i') }}</span>
                                    {% endif %}
                                    {% if watchLinks|length %}
                                        <span class="badge bg-green-lt">Ссылок: {{ watchLinks|length }}</span>
                                    {% endif %}
                                </div>
                                {% if entry.description %}
                                    <p class="lead text-secondary mb-0">{{ entry.description|striptags|truncate(220) }}</p>
                                {% else %}
                                    <p class="lead text-secondary mb-0">Описание фильма скоро появится.</p>
                                {% endif %}
                            </div>

                            {% if genres %}
                                <div>
                                    <div class="text-secondary fw-semibold mb-2">Жанры</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        {% for genre in genres %}
                                            <a href="{{ url('movies', { genre: genre.slug }) }}" class="badge bg-primary-lt text-decoration-none">{{ genre.title }}</a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}

                            {% if collections %}
                                <div>
                                    <div class="text-secondary fw-semibold mb-2">Подборки</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        {% for collection in collections %}
                                            <a href="{{ url('movies', { collection: collection.slug }) }}" class="badge bg-orange-lt text-decoration-none">{{ collection.title }}</a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}

                            <div class="d-flex flex-wrap gap-2 mt-auto">
                                {% if primaryWatchLink and primaryWatchLink.watchLink %}
                                    <a href="{{ primaryWatchLink.watchLink }}" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
                                        {{ primaryWatchLink.label ?: 'Смотреть' }}
                                    </a>
                                {% endif %}
                                {% if watchLinks|length > 1 %}
                                    <a href="#watch-links" class="btn btn-outline-primary">Все ссылки</a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent border-0 pb-0">
                    <h2 class="card-title mb-0">О фильме</h2>
                </div>
                <div class="card-body">
                    {% if entry.description %}
                        <div class="text-secondary">{{ entry.description|nl2br }}</div>
                    {% else %}
                        <p class="text-secondary mb-0">Подробное описание пока не заполнено.</p>
                    {% endif %}
                </div>
            </section>

            {% if genres %}
                <section class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-transparent border-0 pb-0">
                        <h2 class="card-title mb-0">Жанры</h2>
                    </div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2">
                            {% for genre in genres %}
                                <a href="{{ url('movies', { genre: genre.slug }) }}" class="btn btn-outline-primary btn-sm">{{ genre.title }}</a>
                            {% endfor %}
                        </div>
                    </div>
                </section>
            {% endif %}

            {% if collections %}
                <section class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-transparent border-0 pb-0">
                        <h2 class="card-title mb-0">Подборки</h2>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            {% for collection in collections %}
                                {% set collectionImage = null %}
                                {% if collection.cover is defined %}
                                    {% set collectionImage = collection.cover.one() %}
                                {% elseif collection.coverImage is defined %}
                                    {% set collectionImage = collection.coverImage.one() %}
                                {% endif %}

                                <div class="col-12 col-md-6">
                                    <a href="{{ url('movies', { collection: collection.slug }) }}" class="card card-link text-decoration-none h-100 overflow-hidden">
                                        {% if collectionImage %}
                                            <div class="ratio ratio-16x9">
                                                <img src="{{ collectionImage.url }}" alt="{{ collection.title }}" class="object-fit-cover" loading="lazy">
                                            </div>
                                        {% else %}
                                            <div class="ratio ratio-16x9 bg-secondary-lt d-flex align-items-center justify-content-center text-secondary">
                                                Нет обложки
                                            </div>
                                        {% endif %}
                                        <div class="card-body">
                                            <div class="fw-semibold text-body">{{ collection.title }}</div>
                                        </div>
                                    </a>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </section>
            {% endif %}
        </div>
    </div>
{% endblock %}
